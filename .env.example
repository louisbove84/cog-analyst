# Copy to .env and fill in. Only needed to RUN the LLM extractor
# (the deterministic test suite needs none of these).

# --- OpenAI (default backend) ---
# OPENAI_API_KEY=sk-...

# --- Local LLM (Ollama / LM Studio / vLLM) ---
# COG_LLM_BASE_URL=http://localhost:11434/v1
# COG_LLM_MODEL=qwen2.5
# COG_LLM_API_KEY=ollama

# Optional: override the SQLite DB location.
# COG_ANALYST_DB=/absolute/path/to/spratly_fleet.db
