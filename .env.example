# Copy this file to `.env` in THIS folder (the cog-analyst project root,
# next to README.md and pyproject.toml — NOT inside src/cog_analyst/).
# It is auto-loaded by src/cog_analyst/config.py at startup.
# Only needed to RUN the COG agent (nodes 2–4); ingest + tests need no API key.
#
# Pick ONE backend below by setting COG_LLM_BACKEND, then fill in that section.

# =====================================================================
# Backend switch: "openai" (hosted ChatGPT) or "ollama" (local). Default: openai
# =====================================================================
COG_LLM_BACKEND=openai

# --- Option A: OpenAI / ChatGPT (no local install needed) ------------
# Use this if you can't or don't want to download Ollama.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Optional: override the default model (gpt-4o-mini).
# COG_LLM_MODEL=gpt-4o-mini

# --- Option B: Local Ollama (free, offline) --------------------------
# Set COG_LLM_BACKEND=ollama above, then:
#   1) install Ollama (https://ollama.com)
#   2) ollama pull qwen2.5      # or llama3.1:8b
#   3) ollama serve
# No API key required. Defaults: base_url=http://localhost:11434/v1, model=qwen2.5
# COG_LLM_MODEL=qwen2.5

# --- Advanced: any other OpenAI-compatible server (LM Studio, vLLM) --
# Setting a base URL overrides the backend switch above.
# COG_LLM_BASE_URL=http://localhost:1234/v1
# COG_LLM_MODEL=my-model
# COG_LLM_API_KEY=not-needed-for-local

# =====================================================================
# RAG embeddings (only for the retrieve_context node).
# Default backend is GOOGLE (hosted Gemini embeddings) — needs an API key.
# Get one at https://aistudio.google.com/apikey
# (xAI/Grok has no embeddings endpoint, so the chat backend stays separate.)
# =====================================================================
GEMINI_API_KEY=...
# Optional overrides:
# COG_EMBED_BACKEND=google           # or "local" for sentence-transformers
# COG_EMBED_MODEL=gemini-embedding-001
# COG_EMBED_DIM=768                  # 768 | 1536 | 3072
# COG_EMBED_API_KEY=...              # falls back to GEMINI_API_KEY / GOOGLE_API_KEY
#
# --- Local embeddings alternative (no API key, offline) -------------
# Set COG_EMBED_BACKEND=local and install:  pip install -e '.[rag-local]'
# COG_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
